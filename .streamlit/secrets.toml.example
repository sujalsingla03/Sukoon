# Sukoon - Streamlit secrets example
# Use this format in Streamlit Community Cloud: App -> Settings -> Secrets.
# You can also copy this to `.streamlit/secrets.toml` for local testing.

# LLM configuration (works when .env is not available, e.g. Streamlit Cloud)
LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_replace_me"
GROQ_MODEL = "llama-3.3-70b-versatile"
GROQ_API_URL = "https://api.groq.com/openai/v1"

# Optional Gemini keys (only if using LLM_PROVIDER="gemini")
# GOOGLE_API_KEY = "replace_me"
# GEMINI_MODEL = "gemini-1.5-flash"

# Google OAuth configuration (optional)
# Get client_id and client_secret from:
# https://console.cloud.google.com/apis/credentials
# Redirect URI examples:
# - Local: http://localhost:8501/oauth2callback
# - Cloud: https://your-app-name.streamlit.app/oauth2callback

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "your-random-secret-at-least-32-chars-long"
client_id = "your-google-client-id.apps.googleusercontent.com"
client_secret = "your-google-client-secret"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
